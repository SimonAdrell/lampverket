{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "HomeAssistant": {
    "McpEndpointPath": "/mcp",
    "Devices": [
      {
        "Friendly": "Banan",
        "Area": "Bedroom",
        "EntityId": "light.banan",
        "Actions": [
          "on",
          "off",
          "brightness"
        ]
      },
      {
        "Friendly": "Living room ceiling",
        "Area": "Living Room",
        "EntityId": "light.livingroom_ceiling",
        "Actions": [
          "on",
          "off",
          "brightness"
        ]
      },
      {
        "Friendly": "Living room speaker",
        "Area": "Living Room",
        "EntityId": "media_player.livingroom",
        "Actions": [
          "volume",
          "play"
        ]
      }
    ],
    "Tools": {
      "TurnOn": "HassTurnOn",
      "TurnOff": "HassTurnOff",
      "LightSet": "HassLightSet",
      "SetVolume": "HassSetVolume",
      "MediaSearchAndPlay": "HassMediaSearchAndPlay",
      "GetLiveContext": "GetLiveContext"
    }
  }
}