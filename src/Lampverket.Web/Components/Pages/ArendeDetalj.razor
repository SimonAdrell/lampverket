@page "/arende/{Diarienummer}"
@rendermode InteractiveServer
@inject IAnsokanService Handlaggare
@inject IArendeNotifier Notifier
@using Lampverket.Core
@implements IDisposable

<h1>Ärende @Diarienummer</h1>

@if (_arende is null)
{
    <p>Laddar…</p>
}
else if (_arende.Beslut is null)
{
    <p class="status-pill underhandlaggning">@(_steg ?? "Under handläggning")</p>
    <p>Ärendet bereds. Beslutet presenteras här när handläggningen är klar.</p>
}
else
{
    <div class="beslut-card">
        <pre class="beslut-header">LAMPVERKET
Myndigheten för Hemautomation

BESLUT</pre>
        <table class="beslut-meta">
            <tr>
                <th>Diarienummer:</th>
                <td>@_arende.Diarienummer</td>
            </tr>
            <tr>
                <th>Datum:</th>
                <td>@_arende.Beslut.Datum.ToString("yyyy-MM-dd")</td>
            </tr>
            <tr>
                <th>Handläggare:</th>
                <td>Handläggaragent "Bo Sken"</td>
            </tr>
            <tr>
                <th>Sökande:</th>
                <td>@_arende.Ansokan.Sokande</td>
            </tr>
        </table>

        <p class="status-pill @_arende.Status.CssKlass()">@_arende.Status.Text()</p>

        <p class="beslut-typ">@BeslutRubrik(_arende.Beslut)</p>
        <p>@_arende.Beslut.Beslutstext</p>

        <h3>Motivering</h3>
        <p>@_arende.Beslut.Motivering</p>

        @if (_arende.Beslut.Lagrum.Length > 0)
        {
            <ul>
                @foreach (var lag in _arende.Beslut.Lagrum)
                {
                    <li>@lag</li>
                }
            </ul>
        }

        <h3>Hur man överklagar</h3>
        <p>@_arende.Beslut.Overklagandehanvisning</p>

        @if (_arende.Beslut is VerkstalltBeslut verk)
        {
            <h3>Verkställighet</h3>
            @* Verkställt ⇒ åtgärden bekräftad (även äldre diariet-rader utan utfall). Beslutat betyder
               att åtgärden ännu inte verkställts — antingen misslyckat försök eller inget försök alls. *@
            @if (_arende.Status == Arendestatus.Verkstallt)
            {
                <p>@verk.Verkstallighet</p>
            }
            else if (_arende.Verkstallighetsutfall == Verkstallighetsstatus.Misslyckad)
            {
                <p>Beslutad åtgärd: @verk.Verkstallighet</p>
                <p class="verkstallighet-hinder">
                    Verkställighetshinder: beslutet har fattats men åtgärden kunde inte verkställas.
                    Ärendet kvarstår i status Beslutat i avvaktan på förnyad verkställighet.
                </p>
            }
            else
            {
                <p>Beslutad åtgärd: @verk.Verkstallighet</p>
                <p class="verkstallighet-hinder">
                    Verkställighet har ännu inte bekräftats. Ärendet kvarstår i status
                    Beslutat i avvaktan på verkställighet.
                </p>
            }
        }

        @if (_arende.Beslut is Avslag or Avvisning)
        {
            <a class="overklaga-btn" href="/ny-ansokan">Överklaga beslut</a>
        }
    </div>
}

@code {
    [Parameter]
    public string Diarienummer { get; set; } = string.Empty;

    private Core.Arende? _arende;
    private string? _steg;
    private IDisposable? _subscription;
    private IDisposable? _stegSubscription;

    private static string BeslutRubrik(Beslut b) => b switch
    {
        Bifall => "Bifall",
        DelvisBifall => "Delvis bifall",
        Avslag => "Avslag",
        Avvisning => "Avvisning",
        Bordlaggning => "Bordläggning",
        _ => "Beslut"
    };

    // Runs on every parameter change, so navigating between ärenden re-subscribes to the new
    // diarienummer instead of leaking a subscription to the old one.
    protected override async Task OnParametersSetAsync()
    {
        _subscription?.Dispose();
        _subscription = null;
        _stegSubscription?.Dispose();
        _stegSubscription = null;
        _steg = null;

        _arende = await Handlaggare.HamtaArendeAsync(Diarienummer);

        if (_arende?.Beslut is not null)
        {
            return;
        }

        _subscription = Notifier.Subscribe(Diarienummer, arende =>
            InvokeAsync(() =>
            {
                _arende = arende;
                StateHasChanged();
            }));

        // Live handläggningssteg (t.ex. "Granskar hemförhållanden") medan beslutet ännu inte fattats.
        _stegSubscription = Notifier.SubscribeSteg(Diarienummer, steg =>
            InvokeAsync(() =>
            {
                _steg = steg;
                StateHasChanged();
            }));

        // Close the race: beslut may have arrived between the initial diariet read and the subscribe.
        var fresh = await Handlaggare.HamtaArendeAsync(Diarienummer);
        if (fresh?.Beslut is not null)
        {
            _arende = fresh;
            _subscription.Dispose();
            _subscription = null;
            _stegSubscription.Dispose();
            _stegSubscription = null;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _subscription?.Dispose();
        _stegSubscription?.Dispose();
    }
}
