@page "/ny-ansokan"
@rendermode InteractiveServer
@inject IAnsokanService Handlaggare
@inject IUserSession Session
@inject NavigationManager Nav
@inject IOptions<HomeAssistantOptions> HaOptions
@using Lampverket.Agent.HomeAssistant
@using Lampverket.Core
@using Microsoft.Extensions.Options

<h1>Ny ansökan</h1>

@if (Session.Namn is null)
{
    <p class="driftinfo-banner">
        Du är inte inloggad via BankID.
        Lampverket accepterar ansökningar från ej autentiserade medborgare
        i enlighet med offentlighetsprincipen — personnummer används som identifierare.
    </p>
}

<form @onsubmit="Submit" @onsubmit:preventDefault="true">
    <div>
        <label for="personnummer">Personnummer (obligatoriskt)</label>
        <input id="personnummer" type="text" placeholder="ÅÅÅÅMMDD-XXXX" @bind="_personnummer" />
        @if (_personnummerError is not null)
        {
            <span class="field-error">@_personnummerError</span>
        }
    </div>

    <div>
        <label for="arendetyp">Ärendetyp (obligatoriskt)</label>
        <select id="arendetyp" @bind="_arendetyp">
            @foreach (var t in Enum.GetValues<Arendetyp>())
            {
                <option value="@t">@t.Text()</option>
            }
        </select>
    </div>

    <div>
        <label for="berord-enhet">Berörd enhet (obligatoriskt)</label>
        <select id="berord-enhet" @bind="_berordEnhet">
            @foreach (DeviceMapEntry enhet in HaOptions.Value.Devices)
            {
                <option value="@enhet.EntityId">@enhet.Friendly (@enhet.Area)</option>
            }
        </select>
        @if (_berordEnhetError is not null)
        {
            <span class="field-error">@_berordEnhetError</span>
        }
    </div>

    @if (_arendetyp is Arendetyp.Ljusstyrka or Arendetyp.Volym)
    {
        <div>
            <label for="onskad-atgard-range">Önskad nivå (0-100 %)</label>
            <input id="onskad-atgard-range" type="range" min="0" max="100" @bind="_onskadAtgard" />
            <span>@_onskadAtgard %</span>
        </div>
    }
    else if (_arendetyp is Arendetyp.Media)
    {
        <div>
            <label for="onskad-atgard-text">Sökterm för media (obligatoriskt)</label>
            <input id="onskad-atgard-text" type="text" @bind="_onskadAtgardText" />
            @if (_onskadAtgardTextError is not null)
            {
                <span class="field-error">@_onskadAtgardTextError</span>
            }
        </div>
    }

    <div>
        <label for="motivering">Motivering till ansökan (obligatoriskt)</label>
        <textarea id="motivering" @bind="_motivering"></textarea>
        @if (_motiveringError is not null)
        {
            <span class="field-error">@_motiveringError</span>
        }
    </div>

    <div>
        <label for="onskat-datum">Önskat verkställighetsdatum</label>
        <input id="onskat-datum" type="date" @bind="_onskatDatum" />
    </div>

    <div>
        <input id="forsäkran" type="checkbox" @bind="_forsakran" />
        <label for="forsäkran">
            Jag försäkrar på heder och samvete att uppgifterna är riktiga.
            (obligatoriskt)
        </label>
        @if (_forsakranError is not null)
        {
            <span class="field-error">@_forsakranError</span>
        }
    </div>

    <div>
        <button type="submit">Skicka in ansökan</button>
        <a href="/">Avbryt</a>
    </div>
</form>

@code {
    private string _personnummer = string.Empty;
    private Arendetyp _arendetyp;
    private string _berordEnhet = string.Empty;
    private int _onskadAtgard = 50;
    private string _onskadAtgardText = string.Empty;
    private string _motivering = string.Empty;
    private DateOnly _onskatDatum = DateOnly.FromDateTime(DateTime.Today);
    private bool _forsakran;

    private string? _personnummerError;
    private string? _motiveringError;
    private string? _forsakranError;
    private string? _onskadAtgardTextError;
    private string? _berordEnhetError;

    protected override void OnInitialized()
    {
        var first = HaOptions.Value.Devices.FirstOrDefault();
        if (first is not null)
        {
            _berordEnhet = first.EntityId;
        }
    }

    private async Task Submit()
    {
        _personnummerError = null;
        _motiveringError = null;
        _forsakranError = null;
        _onskadAtgardTextError = null;
        _berordEnhetError = null;

        var valid = true;

        var device = HaOptions.Value.Devices.FirstOrDefault(d => d.EntityId == _berordEnhet);
        if (device is null)
        {
            _berordEnhetError = "Välj en giltig enhet.";
            valid = false;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(
                _personnummer, @"^\d{8}-\d{4}$"))
        {
            _personnummerError = "Personnummer måste anges i formatet ÅÅÅÅMMDD-XXXX.";
            valid = false;
        }
        else if (!DateOnly.TryParseExact(_personnummer[..8], "yyyyMMdd", out _))
        {
            _personnummerError = "Personnummer innehåller ett ogiltigt datum.";
            valid = false;
        }

        if (_arendetyp is Arendetyp.Media && string.IsNullOrWhiteSpace(_onskadAtgardText))
        {
            _onskadAtgardTextError = "Sökterm krävs för uppspelning av media.";
            valid = false;
        }

        if (string.IsNullOrWhiteSpace(_motivering))
        {
            _motiveringError = "Motivering krävs.";
            valid = false;
        }

        if (!_forsakran)
        {
            _forsakranError = "Du måste lämna försäkran för att skicka in ansökan.";
            valid = false;
        }

        if (!valid)
        {
            return;
        }

        string? onskadAtgard = _arendetyp switch
        {
            Arendetyp.Ljusstyrka or Arendetyp.Volym => _onskadAtgard.ToString(),
            Arendetyp.Media => _onskadAtgardText,
            _ => null
        };

        var ansokan = new Ansokan
        {
            Personnummer = _personnummer,
            Sokande = Session.Namn ?? _personnummer,
            Arendetyp = _arendetyp,
            BerordEnhet = new Enhet(device!.EntityId, device.Friendly),
            OnskadAtgard = onskadAtgard,
            Motivering = _motivering,
            OnskatDatum = _onskatDatum
        };

        var arende = await Handlaggare.RegisterAnsokanAsync(ansokan);
        Nav.NavigateTo($"/arende/{arende.Diarienummer}");
    }
}
